# PostgreSQL
POSTGRES_USER=ethara
POSTGRES_PASSWORD=ethara_dev_password
POSTGRES_DB=ethara_seat_allocation
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Backend
APP_NAME=Ethara Seat Allocation & Project Mapping System
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://ethara:ethara_dev_password@localhost:5432/ethara_seat_allocation
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=30
DB_ECHO=false
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173
SECRET_KEY=change-me-in-production
ENVIRONMENT=development

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
